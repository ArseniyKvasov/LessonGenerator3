API_KEY=your_service_api_key_here

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

GROQ_TIMEOUT_SECONDS=30
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1200

POLLINATIONS_API_KEY=your_pollinations_api_key_here
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_TIMEOUT_SECONDS=60

# Low-resource defaults: small image, low quality, mini/flash-style models.
POLLINATIONS_IMAGE_MODEL=gptimage
POLLINATIONS_IMAGE_SIZE=512x512
POLLINATIONS_IMAGE_QUALITY=low
POLLINATIONS_AUDIO_MODEL=qwen-tts
POLLINATIONS_AUDIO_VOICE=alloy
POLLINATIONS_AUDIO_FORMAT=mp3
